{
  "title": "Unified App & System Monitor (Prometheus)",
  "uid": "unified-001",
  "refresh": "10s",
  "panels": [
    {
      "type": "gauge",
      "title": "Current Active Tasks",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" }, 
      "targets": [{ "expr": "current_tasks_total" }],
      "fieldConfig": { "defaults": { "min": 0, "max": 100, "color": { "mode": "thresholds" } } }
    },
    {
      "type": "gauge",
      "title": "CPU Usage (%)",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode='idle'}[2m])) * 100)" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "type": "gauge",
      "title": "Memory Usage (%)",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [{ "expr": "node_memory_Active_bytes / node_memory_MemTotal_bytes * 100" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "type": "stat",
      "title": "P99 Latency",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))" }],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" } }, "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 0.5, "color": "red" }] } }
    },
    {
      "type": "timeseries",
      "title": "Network Traffic (In/Out)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total[5m])", "legendFormat": "Inbound" },
        { "expr": "rate(node_network_transmit_bytes_total[5m])", "legendFormat": "Outbound" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "type": "timeseries",
      "title": "HTTP Error Rate (5xx)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [{ "expr": "sum(rate(http_requests_total{status=~'5..'}[5m]))", "legendFormat": "Errors/sec" }],
      "fieldConfig": { "defaults": { "color": { "fixedColor": "red", "mode": "fixed" } } }
    }
  ],
  "schemaVersion": 36
}
