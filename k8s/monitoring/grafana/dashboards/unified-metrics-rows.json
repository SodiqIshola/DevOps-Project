{
  "uid": "unified-metrics-rows",
  "title": "Unified Metrics: Grouped by Row",
  "tags": ["prometheus", "infrastructure", "dynamic", "rows"],
  "timezone": "browser",
  "schemaVersion": 36,
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(container_cpu_usage_seconds_total, namespace)",
        "query": "label_values(container_cpu_usage_seconds_total, namespace)",
        "refresh": 1,
        "label": "1. Namespace"
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(container_cpu_usage_seconds_total{namespace=\"$namespace\"}, pod)",
        "query": "label_values(container_cpu_usage_seconds_total{namespace=\"$namespace\"}, pod)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "label": "2. Pod Name"
      },
      {
        "name": "container",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(container_cpu_usage_seconds_total{namespace=\"$namespace\", pod=~\"$pod\"}, container)",
        "query": "label_values(container_cpu_usage_seconds_total{namespace=\"$namespace\", pod=~\"$pod\"}, container)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "label": "3. Container"
      }
    ]
  },
  "panels": [
    {
      "title": "Resource Usage for $namespace",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "CPU Usage: $pod",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"$namespace\", pod=~\"$pod\", container=~\"$container\"}[1m])",
          "legendFormat": "{{pod}} [{{container}}]"
        }
      ]
    },
    {
      "title": "Memory Usage: $pod",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{namespace=\"$namespace\", pod=~\"$pod\", container=~\"$container\"}",
          "legendFormat": "{{pod}} [{{container}}]"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Network Traffic (Namespace: $namespace)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": true
    },
    {
      "title": "Network I/O: $pod",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "targets": [
        { "expr": "rate(container_network_receive_bytes_total{namespace=\"$namespace\", pod=~\"$pod\"}[5m])", "legendFormat": "{{pod}} RX" },
        { "expr": "rate(container_network_transmit_bytes_total{namespace=\"$namespace\", pod=~\"$pod\"}[5m])", "legendFormat": "{{pod}} TX" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ]
}
