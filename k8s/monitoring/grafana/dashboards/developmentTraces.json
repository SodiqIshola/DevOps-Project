
{
  "uid": "node-js-traces-dev",
  "tags": ["nodejs", "traces", "development"],
  "title": "Node.js Traces & Metrics (Development)",
  "panels": [
    {
      "title": "Service Map (Live Architecture)",
      "type": "nodeGraph",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "query": "service-graph{environment=\"development\"}",
          "refId": "A"
        }
      ],
      "description": "Visualizes service topology filtered for dev environment"
    },
    {
      "title": "Service Request Rate (RED - Rate)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "sum(rate(tempo_span_metrics_calls_total{service_name=\"node-app\", environment=\"development\"}[1m]))",
          "legendFormat": "Requests/sec",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Service Error Rate (RED - Errors)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "targets": [
        {
          "expr": "sum(rate(tempo_span_metrics_calls_total{service_name=\"node-app\", status_code=\"STATUS_CODE_ERROR\", environment=\"development\"}[1m]))",
          "legendFormat": "Errors/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } } }
    },
    {
      "title": "P95 Service Latency (RED - Duration)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(tempo_span_metrics_latency_bucket{service_name=\"node-app\", environment=\"development\"}[1m])) by (le))",
          "legendFormat": "p95 Latency (ms)",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "title": "Trace Search (TraceQL)",
      "type": "traces",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 18 },
      "targets": [
        { 
          "query": "{ .service.name = \"node-app\" && status = error && environment = \"development\" }", 
          "refId": "A",
          "queryType": "traceql"
        }
      ],
      "description": "Showing only development traces with errors for faster debugging"
    }
  ]
}