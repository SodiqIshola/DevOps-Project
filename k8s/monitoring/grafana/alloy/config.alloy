// ============================================================================
// SPAN → METRICS (RED METRICS GENERATION)
// ----------------------------------------------------------------------------
// Converts traces into Prometheus metrics for alerting:
// - Request count
// - Error rate
// - Duration (latency)
// ============================================================================
otelcol.connector.spanmetrics "translator" {

  namespace = "traces_spanmetrics"

  dimension { name = "deployment.environment" }
  dimension { name = "k8s.namespace.name" }
  dimension { name = "http.method" }
  dimension { name = "http.status_code" }
  dimension { name = "service.name" }
  dimension { name = "span.name" }

  histogram {
    explicit {
      buckets = ["100ms", "300ms", "500ms", "1s", "2s", "5s"]
    }
  }


  output {
    metrics = [otelcol.exporter.prometheus.local_prometheus.input]
  }

}

// ============================================================================
// EXPORTERS (TEMPO + PROMETHEUS)
// ============================================================================
otelcol.exporter.otlp "to_tempo" {
  client {
    endpoint = "tempo.monitoring.svc.cluster.local:4317"
    tls { insecure = true }
  }
}

otelcol.exporter.prometheus "local_prometheus" {
  forward_to = [prometheus.remote_write.local_prometheus.receiver]
}


// ============================================================================
// PROMETHEUS REMOTE WRITE (FINAL DESTINATION)
// ----------------------------------------------------------------------------
// Central sink for all metrics (node, container, and span-derived).
// ============================================================================
prometheus.remote_write "local_prometheus" {
  endpoint {
    url = "http://prometheus-operated.monitoring.svc:9090/api/v1/write"
  }
}
