node_modules/
coverage/
junit.xml


# Log files
*.log

# Log Directories
logs/
app-logs/

.dockerignore



# 1. THE BIG ONE: The .terraform folder contains provider binaries (100MB+ each)
# This is what's causing your "file too large" error.
.terraform/
terraform/.terraform/

terraform/aws-ecs/environments/development/.terraform
terraform/aws-ecs/environments/development/.terraform.lock.hcl
terraform/aws-ecs/environments/development/terraform.tfstate
terraform/aws-ecs/environments/development/terraform.tfstate.backup


terraform/aws-eks/.terraform
terraform/aws-eks/.terraform.lock.hcl

terraform/aws-eks/environments/eks-infra/.terraform
terraform/aws-eks/environments/eks-infra/.terraform.lock.hcl
terraform/aws-eks/environments/eks-infra/terraform.tfstate
terraform/aws-eks/environments/eks-infra/terraform.tfstate.backup


terraform/aws-eks/environments/platform/.terraform
terraform/aws-eks/environments/platform/.terraform.lock.hcl
terraform/aws-eks/environments/platform/terraform.tfstate
terraform/aws-eks/environments/platform/terraform.tfstate.backup


# 2. THE SENSITIVE ONES: State files contain your infrastructure's "DNA" and secrets.
*.tfstate
*.tfstate.*
terraform/terraform.tfstate
terraform/terraform.tfstate.backup

# 3. THE LOCK FILE: Prevents version drift (commonly ignored in local learning projects)
.terraform.lock.hcl
terraform/.terraform.lock.hcl

# 4. THE VARIABLES: Often contains passwords/keys. Never push these!
*.tfvars
*.tfvars.json




