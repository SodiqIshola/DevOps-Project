{
  "name": "task-app",
  "version": "1.0.0",
  "description": "Simple Node.js Task Manager API with Jest test suite and SonarQube integration",
  "main": "index.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node index.js",
    "dev": "NODE_ENV=development nodemon index.js",
    "build": "webpack",
    "test": "jest --coverage --reporters=default --reporters=jest-junit",
    "lint": "eslint .",
    "prestart": "npm run test"
  },
  "dependencies": {
    "express": "^4.18.2",
    "prom-client": "^15.1.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "esbuild-loader": "^3.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.0",
    "jest": "^29.6.1",
    "jest-junit": "^16.0.0",
    "jest-sonar": "^0.2.9",
    "nodemon": "^3.1.0",
    "supertest": "^7.1.1",
    "webpack": "^5.97.0",
    "webpack-cli": "^5.1.4"
  },
  "jest": {
    "reporters": [
      "default",
      [
        "jest-sonar",
        {
          "outputDirectory": "coverage",
          "outputName": "sonar-report.xml"
        }
      ],
      [
        "jest-junit",
        {
          "outputDirectory": ".",
          "outputName": "junit.xml",
          "uniqueOutputName": "false"
        }
      ]
    ],
    "coverageReporters": [
      "lcov"
    ]
  }
}
